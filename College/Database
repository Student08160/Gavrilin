SELECT * FROM Orders;

/*Должны быть все заказы, добавив к ним название товара, его цену из Products. Должны быть колонки: 
Order_id, Order_date, Product_name, Price, Quantity */

SELECT Orders.Id AS Order_id, Orders.Order_Date AS Order_date, Products.Name AS Product_name,
Products.Price AS Price, Orders.Customer_name AS Customer_name, Orders.Quantity AS Quantity
FROM Orders
FULL OUTER JOIN Products ON Products.Id = Orders.Product_id
GROUP BY Order_id, Products.Name, Products.Price;

-- Вывести имя покупателя и количество его заказов
SELECT SUM(Quantity) AS Count, Customer_name FROM Orders
GROUP BY Customer_name
ORDER BY Count;

