CREATE TABLE Employees (
	Id SERIAL UNIQUE PRIMARY KEY NOT NULL,
	Name VARCHAR(50),
	Age INT,
	Department VARCHAR(50),
	Salary DECIMAL
);

CREATE TABLE Products (
	Id SERIAL UNIQUE PRIMARY KEY NOT NULL,
	Name VARCHAR(50),
	Price DECIMAL,
	Category VARCHAR(50),
	Stock_quantity INT
);

CREATE TABLE Orders (
	Id SERIAL UNIQUE PRIMARY KEY NOT NULL,
	Product_id INT NOT NULL,
	Quantity INT,
	Order_date DATE,
	Customer_name VARCHAR(50)
);

